      <aliases enabled='yes' />
      <column caption='2020 Units Sold' datatype='integer' name='[2020_units_sold]' role='measure' type='quantitative' />
      <column caption='2021 Start Stock' datatype='integer' name='[2021_start_stock]' role='measure' type='quantitative' />
      <column caption='Advertisement Costs' datatype='real' name='[Advertisement_Costs]' role='measure' type='quantitative' />
      <column caption='Total COGS 2020' datatype='real' name='[Calculation_1009932275405230082]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Factory_Equipment_Rent_Costs]+[Factory_Labor_Costs]+[Raw_Material_Cost])*[2020_units_sold]' />
      </column>
      <column caption='Revenue 2020' datatype='real' name='[Calculation_1009932275416657923]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Retail_Price]* [2020_units_sold]' />
      </column>
      <column caption='Profit 2020' datatype='real' name='[Calculation_1009932275417325573]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1009932275416657923]-[Calculation_1009932275405230082]' />
      </column>
      <column caption='Invoice Year' datatype='integer' name='[Calculation_1009932275427696646]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='YEAR([Invoice_Date])' />
      </column>
      <column caption='Total Orders 2022' datatype='integer' name='[Calculation_1009932275438059527]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [Description]: SUM(IF [Calculation_1009932275427696646]=2022&#13;&#10;THEN [Quantity] &#13;&#10;&#13;&#10;END)}' />
      </column>
      <column caption='Total Orders 2021' datatype='integer' name='[Calculation_1009932275439714312]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [Description]: SUM(IF [Calculation_1009932275427696646]=2021&#13;&#10;THEN [Quantity] &#13;&#10;&#13;&#10;END)}' />
      </column>
      <column caption='2021 End Stock' datatype='integer' name='[Calculation_1009932275442696202]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[2021_start_stock]-[Calculation_1009932275439714312]' />
      </column>
      <column caption='Direct Costs' datatype='real' name='[Calculation_1009932275443392523]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Factory_Equipment_Rent_Costs]+[Factory_Labor_Costs]+[Raw_Material_Cost]' />
      </column>
      <column caption='total cogs 2021' datatype='real' name='[Calculation_1009932275446485005]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Raw_Material_Cost]+[Factory_Labor_Costs]+[Factory_Equipment_Rent_Costs])*[Calculation_1009932275439714312]' />
      </column>
      <column caption='Avg Inventory 2021' datatype='real' name='[Calculation_1009932275447726094]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([2021_start_stock]+[Calculation_1009932275442696202])*[Calculation_1009932275443392523]/2' />
      </column>
      <column caption='Revenue 2021' datatype='real' name='[Calculation_580682936213983232]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1009932275439714312]*[Retail_Price]' />
      </column>
      <column caption='Revenue 2021 Percent' datatype='real' name='[Calculation_580682936215031810]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_580682936213983232])/TOTAL(SUM([Calculation_580682936213983232]))*100'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Revenue 2020 Percent' datatype='real' name='[Calculation_580682936221712387]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_1009932275416657923])/TOTAL(SUM([Calculation_1009932275416657923]))*100'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Running Total Revenue 2021 Percent' datatype='real' datatype-customized='true' name='[Calculation_580682936223342596]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RUNNING_SUM([Calculation_580682936215031810])'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='ABC 2021' datatype='string' name='[Calculation_580682936275283974]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_580682936223342596]&lt;=70 THEN &apos;A [High Value]&apos;&#13;&#10;ELSEIF [Calculation_580682936223342596]&lt;=90 THEN &apos;B [Medium Value]&apos;&#13;&#10;ELSE &apos;C [Low Value]&apos;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Inventory Turnover 2021' datatype='real' name='[Calculation_580682936278720520]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1009932275446485005]/[Calculation_1009932275447726094]' />
      </column>
      <column caption='COGS Revenue Ratio' datatype='real' name='[Calculation_580682936325218313]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1009932275446485005]/[Calculation_580682936213983232]' />
      </column>
